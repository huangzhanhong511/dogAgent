# ============================================
# dogAgent 环境配置
# ============================================
# 复制此文件为 .env 并填入你的 API Key:
#   cp .env.example .env

# ── LLM 配置 ──

# 提供商: qwen / openai
LLM_PROVIDER=qwen

# Qwen (通义千问) 配置 — 默认推荐
QWEN_API_KEY=sk-9ecf610bd5a14298b49a9dc702beda0c
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1  # 默认值，可不设
CHAT_MODEL=qwen-plus

# OpenAI 配置（如果用 OpenAI，改 LLM_PROVIDER=openai 并填下面）
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o

# ── JWT 认证 ──

# 生产环境请替换为随机字符串（如 openssl rand -hex 32）
JWT_SECRET=dogagent-dev-secret-change-in-production

# ── 可选配置 ──

# Obsidian 同步目录（不配置则跳过同步）
# OBSIDIAN_VAULT_DIR=/path/to/your/obsidian/vault

# 后台任务线程池大小
# BG_MAX_WORKERS=4

# 默认用户 ID（CLI 模式下使用）
# DOG_AGENT_USER=default_user
